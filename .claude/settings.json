{
  "permissions": {
    "allow": [
      "mcp__codegraph__*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codegraph prompt-hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(git branch --show-current 2>/dev/null)\" = \"main\" ]; then echo 'Direct edits to main are forbidden! Use a feature/bugfix branch or worktree.' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/test-on-edit.sh\"",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "head"
  }
}
